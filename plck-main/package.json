{
  "name": "plck",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "init": "plck init",
    "dev": "plck start",
    "start": "plck start",
    "build:command": "esbuild ./core/commands/index.ts --bundle --minify --outfile=.command/index.js --platform=node --external:esbuild && chmod 777 .command/index.js",
    "add": "plck add",
    "add-unit": "plck add-unit",
    "build": "plck build",
    "help": "plck --help",
    "test": "vitest ./core/test",
    "type-check": "vue-tsc --noEmit -p tsconfig.app.json --composite false",
    "lint": "eslint . --ext .vue,.js,.jsx,.cjs,.mjs,.ts,.tsx,.cts,.mts --fix --ignore-path .gitignore",
    "format": "prettier --write src/"
  },
  "dependencies": {
    "@inquirer/prompts": "^3.2.0",
    "@types/js-yaml": "^4.0.5",
    "aos": "^2.3.4",
    "commander": "^11.0.0",
    "glob": "^10.3.4",
    "js-cookie": "^3.0.5",
    "js-yaml": "^4.1.0",
    "lodash": "^4.17.21",
    "pinia": "^2.1.6",
    "swiper": "^10.2.0",
    "ts-node": "^10.9.1",
    "uuid": "^9.0.1",
    "vue": "^3.3.4",
    "vue-i18n": "^9.2.2",
    "vue-router": "^4.2.2"
  },
  "devDependencies": {
    "@rollup/plugin-yaml": "^4.1.0",
    "@rushstack/eslint-patch": "^1.2.0",
    "@tsconfig/node18": "^2.0.1",
    "@types/aos": "^3.0.4",
    "@types/ejs": "^3.1.2",
    "@types/lodash": "^4.14.195",
    "@types/node": "^18.16.17",
    "@vitejs/plugin-vue": "^4.2.3",
    "@vue/eslint-config-prettier": "^7.1.0",
    "@vue/eslint-config-typescript": "^11.0.3",
    "@vue/tsconfig": "^0.4.0",
    "ejs": "^3.1.9",
    "esbuild": "^0.18.20",
    "eslint": "^8.39.0",
    "eslint-plugin-vue": "^9.11.0",
    "minimatch": "^9.0.2",
    "npm-run-all": "^4.1.5",
    "prettier": "^2.8.8",
    "sass": "^1.69.5",
    "typescript": "~5.0.4",
    "vite": "^4.3.9",
    "vite-plugin-inspect": "^0.7.28",
    "vitest": "^0.32.2",
    "vue-tsc": "^1.6.5"
  },
  "bin": {
    "plck": ".command/index.js"
  }
}
